# Server
SERVER_PORT=3000

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=visionhub
DB_PASSWORD=CHANGE_ME_GENERATE_RANDOM_32_BYTES
DB_NAME=visionhub

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_GENERATE_RANDOM_32_BYTES

# JWT — REQUIRED. Generate with: openssl rand -hex 32
# Server refuses to start if empty or shorter than 32 chars.
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_BYTES_HEX

# 豆包 API (药品识别，doubao-seed-1.6-vision 视觉模型)
DOUBAO_API_KEY=CHANGE_ME
DOUBAO_API_URL=https://ark.cn-beijing.volces.com
# 服务器公网地址（豆包需要公网可访问的图片 URL）
PUBLIC_BASE_URL=http://localhost:3000

# Device Auth
DEVICE_UNIQUE_CODE=CHANGE_ME
DEVICE_XOR_KEY=4B
